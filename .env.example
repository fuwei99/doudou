pp# /.env.example
# ====================================================================
# doubao-2api 配置文件模板
# ====================================================================
#
# 请将此文件重命名为 ".env" 并填入您的参数。
#

# --- 核心安全配置 ---
# 用于保护您 API 服务的访问密钥。
API_MASTER_KEY=1

# --- 部署配置 ---
# 服务端口
NGINX_PORT=8088

# --- 豆包凭证 ---
# 方式1: 单个或多个环境变量 (推荐用于环境变量管理)
# 支持多账号轮询，只需按格式添加 DOUBAO_COOKIE_2, DOUBAO_COOKIE_3, ...
DOUBAO_COOKIE_1=在此处粘贴您的完整 Cookie 字符串

# 方式2: JSON 字符串 (支持带设备指纹的复杂配置)
# DOUBAO_COOKIES_JSON='[{"cookie": "...", "device_id": "...", "fp": "..."}]'

# --- 核心设备指纹 (可选，通常从 FETCH_URL 自动解析) ---
# 如果不设置，程序将使用内置的或自动抓取的指纹
# DOUBAO_DEVICE_ID=
# DOUBAO_FP=
# DOUBAO_TEA_UUID=
# DOUBAO_WEB_ID=

# --- 快捷参数提取 ---
# 粘贴一个完整的 doubao completion 请求 URL，程序会自动从中提取指纹参数
# FETCH_URL=
# FORCE_FETCH_URL=false

# --- 匿名 Cookie 捕获配置 (需要安装 Playwright) ---
# AUTO_FILL=false
# COOKIE_NUM=3
# COOKIE_TIMES=10

# --- 运行参数 ---
# 超时时间（秒）
API_REQUEST_TIMEOUT=180
# 会话缓存时间（秒）
SESSION_CACHE_TTL=3600
# 默认使用的模型
DEFAULT_MODEL=doubao-pro-chat
